<section class="product-lineup">
  <div class="product-lineup__inner">

    {%- if section.settings.heading != blank -%}
      <h2 class="product-lineup__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <ul class="product-lineup__grid">
        {%- for block in section.blocks -%}
          {%- assign product = block.settings.product -%}
          {%- if product != blank -%}
            <li class="product-lineup__item" {{ block.shopify_attributes }}>
              <a class="product-lineup__link" href="{{ product.url }}">
                {%- if product.featured_image != blank -%}
                  <div class="product-lineup__image-wrapper">
                    {{
                      product.featured_image
                      | image_url: width: 600
                      | image_tag: class: 'product-lineup__image', loading: 'lazy', alt: product.title
                    }}
                  </div>
                {%- endif -%}
                <div class="product-lineup__info">
                  <p class="product-lineup__title">{{ product.title }}</p>
                  <p class="product-lineup__price">{{ product.price | money }}</p>
                </div>
              </a>
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    {%- endif -%}

    {%- if section.settings.collection_url != blank and section.settings.collection_label != blank -%}
      <div class="product-lineup__footer">
        <a class="product-lineup__all-link button" href="{{ section.settings.collection_url }}">
          {{ section.settings.collection_label }}
        </a>
      </div>
    {%- endif -%}

  </div>
</section>

{% stylesheet %}
.product-lineup {
  padding: 80px 20px;
  background-color: var(--color-background);
}

.product-lineup__inner {
  max-width: 1100px;
  margin: 0 auto;
}

.product-lineup__heading {
  font-size: clamp(2.4rem, 3vw, 3.6rem);
  font-weight: 600;
  color: var(--color-foreground);
  text-align: center;
  margin: 0 0 48px;
}

.product-lineup__grid {
  list-style: none;
  margin: 0;
  padding: 0;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 32px;
}

.product-lineup__link {
  display: block;
  text-decoration: none;
  color: inherit;
}

.product-lineup__link:hover .product-lineup__image {
  transform: scale(1.03);
}

.product-lineup__image-wrapper {
  overflow: hidden;
  border-radius: 4px;
  aspect-ratio: 1 / 1;
  margin-bottom: 16px;
}

.product-lineup__image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.3s ease;
}

.product-lineup__info {
  padding: 0 4px;
}

.product-lineup__title {
  font-size: 1.6rem;
  font-weight: 500;
  color: var(--color-foreground);
  margin: 0 0 6px;
}

.product-lineup__price {
  font-size: 1.5rem;
  color: var(--color-foreground);
  opacity: 0.7;
  margin: 0;
}

.product-lineup__footer {
  text-align: center;
  margin-top: 48px;
}

.product-lineup__all-link {
  display: inline-block;
  padding: 14px 40px;
  background-color: transparent;
  color: var(--color-foreground);
  border: 2px solid var(--color-foreground);
  text-decoration: none;
  font-size: 1.6rem;
  font-weight: 600;
  border-radius: 4px;
  transition: background-color 0.2s ease, color 0.2s ease;
}

.product-lineup__all-link:hover {
  background-color: var(--color-foreground);
  color: var(--color-background);
}

@media (max-width: 749px) {
  .product-lineup {
    padding: 60px 20px;
  }

  .product-lineup__grid {
    grid-template-columns: 1fr;
    gap: 24px;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Product Lineup",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "見出し",
      "default": "人気の商品"
    },
    {
      "type": "url",
      "id": "collection_url",
      "label": "「すべての商品を見る」リンク先"
    },
    {
      "type": "text",
      "id": "collection_label",
      "label": "「すべての商品を見る」ボタンのテキスト",
      "default": "すべての商品を見る"
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "商品カード",
      "limit": 6,
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "商品"
        }
      ]
    }
  ],
  "presets": [{ "name": "Product Lineup" }]
}
{% endschema %}
