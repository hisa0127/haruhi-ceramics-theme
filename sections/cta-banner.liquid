<section class="cta-banner" style="background-color: {{ section.settings.bg_color }}; color: {{ section.settings.text_color }};">
  <div class="cta-banner__inner">

    {%- if section.settings.heading != blank -%}
      <h2 class="cta-banner__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.subtext != blank -%}
      <p class="cta-banner__subtext">{{ section.settings.subtext }}</p>
    {%- endif -%}

    {%- if section.settings.button_label != blank and section.settings.button_url != blank -%}
      <a class="cta-banner__button" href="{{ section.settings.button_url }}" style="color: {{ section.settings.text_color }}; border-color: {{ section.settings.text_color }};">
        {{ section.settings.button_label }}
      </a>
    {%- endif -%}

  </div>
</section>

{% stylesheet %}
.cta-banner {
  padding: 100px 20px;
  text-align: center;
}

.cta-banner__inner {
  max-width: 640px;
  margin: 0 auto;
}

.cta-banner__heading {
  font-size: clamp(1.75rem, 4vw, 2.75rem);
  font-weight: 700;
  line-height: 1.3;
  margin: 0 0 20px;
}

.cta-banner__subtext {
  font-size: 1.05rem;
  line-height: 1.8;
  opacity: 0.85;
  margin: 0 0 40px;
}

.cta-banner__button {
  display: inline-block;
  padding: 16px 48px;
  border: 2px solid;
  text-decoration: none;
  font-size: 1rem;
  font-weight: 600;
  border-radius: 4px;
  transition: opacity 0.2s ease;
}

.cta-banner__button:hover {
  opacity: 0.75;
}

@media (max-width: 749px) {
  .cta-banner {
    padding: 80px 20px;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "CTA Banner",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "背景色",
      "default": "#C47D5A"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "テキストカラー",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "見出し",
      "default": "あなたの食卓に、信楽の温もりを"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "サブテキスト",
      "default": "¥10,000以上のご購入で送料無料。まずはお気に入りの一点を見つけてください。"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "ボタンのテキスト",
      "default": "商品を見る"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "ボタンのリンク先"
    }
  ],
  "presets": [{ "name": "CTA Banner" }]
}
{% endschema %}
