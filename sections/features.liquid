<section class="features">
  <div class="features__inner">

    {%- if section.settings.heading != blank -%}
      <h2 class="features__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <ul class="features__grid">
        {%- for block in section.blocks -%}
          <li class="features__item" {{ block.shopify_attributes }}>
            {%- if block.settings.icon != blank -%}
              <span class="features__icon">{{ block.settings.icon }}</span>
            {%- endif -%}
            {%- if block.settings.title != blank -%}
              <h3 class="features__title">{{ block.settings.title }}</h3>
            {%- endif -%}
            {%- if block.settings.description != blank -%}
              <p class="features__description">{{ block.settings.description }}</p>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}

  </div>
</section>

{% stylesheet %}
.features {
  padding: 80px 20px;
  background-color: var(--color-background);
}

.features__inner {
  max-width: 1100px;
  margin: 0 auto;
}

.features__heading {
  font-size: clamp(2.4rem, 3vw, 3.6rem);
  font-weight: 600;
  color: var(--color-foreground);
  text-align: center;
  margin: 0 0 56px;
}

.features__grid {
  list-style: none;
  margin: 0;
  padding: 0;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 40px;
}

.features__item {
  text-align: center;
  padding: 40px 24px;
  border: 1px solid rgba(0, 0, 0, 0.08);
  border-radius: 8px;
  background-color: var(--color-background);
}

.features__icon {
  display: block;
  font-size: 4rem;
  margin-bottom: 20px;
  line-height: 1;
}

.features__title {
  font-size: 1.8rem;
  font-weight: 600;
  color: var(--color-foreground);
  margin: 0 0 12px;
}

.features__description {
  font-size: 1.5rem;
  line-height: 1.8;
  color: var(--color-foreground);
  opacity: 0.75;
  margin: 0;
}

@media (max-width: 749px) {
  .features {
    padding: 60px 20px;
  }

  .features__grid {
    grid-template-columns: 1fr;
    gap: 24px;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Features",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "見出し",
      "default": "HARUHI CERAMICSのこだわり"
    }
  ],
  "blocks": [
    {
      "type": "feature_item",
      "name": "こだわりポイント",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "アイコン絵文字",
          "default": "🏺"
        },
        {
          "type": "text",
          "id": "title",
          "label": "タイトル",
          "default": "職人による手作り"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "説明文",
          "default": "一点ずつ丁寧にろくろで成形。機械では出せない温かみと個性があります。"
        }
      ]
    }
  ],
  "presets": [{ "name": "Features" }]
}
{% endschema %}
